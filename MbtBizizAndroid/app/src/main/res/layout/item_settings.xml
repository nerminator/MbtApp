<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="data"
            type="com.daimlertruck.dtag.internal.android.mbt.test.network.entity.settings.SettingObject" />

        <variable
            name="settingchangedcallback"
            type="com.daimlertruck.dtag.internal.android.mbt.test.network.entity.settings.ISettingsChange" />
    </data>

    <RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent">

        <Switch
            android:id="@+id/switchSettingValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="17.3dp"
            android:layout_marginTop="18.1dp"
            android:checked="@{data.value == 1 ? true : false}"
            android:textColor="@color/buttonBackgroundColor"
            android:theme="@style/SCBSwitch"
            app:callbackswitcpri="@{settingchangedcallback}"
            app:data="@{data}" />


        <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCS
            android:id="@+id/tvSettingName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignBaseline="@+id/switchSettingValue"
            android:layout_alignParentStart="true"
            android:layout_marginEnd="15dp"
            android:layout_marginStart="20dp"
            android:layout_toLeftOf="@id/switchSettingValue"
            android:text="@{data.title}"
            android:layout_marginBottom="15dp"
            android:textColor="@android:color/white"
            android:textSize="17.3dp" />

        <!--<com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCS
            android:id="@+id/tvSettingDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_below="@+id/tvSettingName"
            android:layout_marginBottom="15dp"
            android:layout_marginEnd="15dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="15dp"
            android:layout_toLeftOf="@id/switchSettingValue"
            android:text="@{data.description}"
            android:textColor="@color/thirtyPercentOpacityTextColor"
            android:textSize="13.3dp" />-->

        <View
            android:id="@+id/viewSeperator"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:alpha="0.2"
            android:layout_below="@+id/tvSettingName"
            android:background="@android:color/white" />

    </RelativeLayout>
</layout>