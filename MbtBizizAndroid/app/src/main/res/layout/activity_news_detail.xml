<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.daimlertruck.dtag.internal.android.mbt.test.ui.newsDetail.VMNewsDetail" />

        <variable
            name="discountViewState"
            type="com.daimlertruck.dtag.internal.android.mbt.test.ui.newsDetail.DiscountCodeViewState" />

        <import type="android.text.TextUtils" />

        <import type="android.view.View" />

    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/coordinator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_background"
        tools:context=".ui.newsDetail.NewsDetailActivity">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar"
            android:layout_width="match_parent"
            android:layout_height="275dp"
            android:background="@android:color/transparent">
            <!--app:layout_behavior="@string/appbar_fling_fix_behavior"-->

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@+id/collapsingToolbar"
                android:layout_width="match_parent"
                android:layout_height="275dp"
                app:contentScrim="@drawable/gradient_actionbar_background"
                app:layout_scrollFlags="scroll|exitUntilCollapsed|snap">

                <ImageView
                    android:id="@+id/imageNewsDetail"
                    android:layout_width="match_parent"
                    android:layout_height="275dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    app:layout_collapseMode="parallax"
                    app:layout_collapseParallaxMultiplier="0.7" />

                <com.denzcoskun.imageslider.ImageSlider
                    android:id="@+id/imageSlider"
                    android:layout_width="match_parent"
                    android:layout_height="275dp"
                    android:visibility="gone"
                    app:iss_auto_cycle="true"
                    app:iss_delay="5000"
                    app:iss_period="5000"
                    app:iss_placeholder="@color/actionBg1"
                    app:layout_collapseMode="parallax"
                    app:layout_collapseParallaxMultiplier="0.7"
                    tools:visibility="visible" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:layout_alignParentBottom="true"
                    android:alpha="0.7"
                    android:background="@drawable/news_detail_toolbar_gradient"
                    app:layout_collapseMode="pin" />

                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    app:layout_collapseMode="pin"
                    app:popupTheme="@style/AppTheme.PopupOverlay"
                    app:theme="@style/ToolbarColoredBackArrow" />
            </com.google.android.material.appbar.CollapsingToolbarLayout>

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedNewsDetail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_background"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:id="@+id/container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="20dp"
                android:paddingHorizontal="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imageView2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_date" />

                    <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCS
                        android:id="@+id/tvDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:lineSpacingExtra="4sp"
                        android:text="@{viewModel.newsDetail.dateInfo}"
                        android:textColor="#00adef"
                        android:textSize="18sp"
                        tools:text="12 Nisan 2018, Perşembe" />
                </LinearLayout>

                <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCS
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="35dp"
                    android:text="@{viewModel.newsDetail.title}"
                    android:textColor="#ffffff"
                    android:textSize="22sp"
                    tools:text="Buraya Başlık Gelecek" />


                <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCS
                    android:id="@+id/tvText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="6sp"
                    android:text="@{viewModel.newsDetail.text}"
                    android:textColor="#80ffffff"
                    android:textSize="18sp"
                    tools:text="Maecenas faucibus mollis interdum. Praesent commodo cursus magna, vel scelerisque nisl consectetur et.
Etiam porta sem malesuada magna mod nibh ultricies vehicula ut id elit. Maecenas sed diam eget risus varius blandit sit amet non magna." />


                <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCA
                    android:id="@+id/tvSubTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="35dp"
                    android:text="@{viewModel.newsDetail.subTitle}"
                    android:textColor="#ffffff"
                    android:textSize="18sp"
                    android:visibility="@{TextUtils.isEmpty(viewModel.newsDetail.subTitle)?View.GONE:View.VISIBLE}"
                    tools:text="Buraya Başlık Gelecek" />


                <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCS
                    android:id="@+id/tvSubText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="6sp"
                    android:text="@{viewModel.newsDetail.subText}"
                    android:textColor="#80ffffff"
                    android:textSize="18sp"
                    android:visibility="@{TextUtils.isEmpty(viewModel.newsDetail.subText)?View.GONE:View.VISIBLE}"
                    tools:text="Maecenas faucibus mollis interdum. Praesent commodo cursus magna, vel scelerisque nisl consectetur et.
Etiam porta sem malesuada magna mod nibh ultricies vehicula ut id elit. Maecenas sed diam eget risus varius blandit sit amet non magna." />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginHorizontal="15dp"
            android:layout_marginBottom="15dp"
            android:orientation="vertical">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewPdf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/pdf_background_color"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.ButtonDemiCS
                android:id="@+id/btnLink"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_gravity="bottom"
                android:background="#f7151922"
                android:drawableStart="@drawable/ic_link"
                android:gravity="center"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:text="@{viewModel.newsDetail.url}"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:visibility="@{viewModel.linkVisibility? View.VISIBLE:View.GONE}"
                tools:text="http://www.siteadi.com.tr" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:background="@color/alertDialogBg"
                android:onClick="@{viewModel::onDiscountCodeAreaClicked}"
                android:visibility="@{discountViewState.getDiscountLayoutVisibility() ? View.VISIBLE : View.GONE}"
                tools:visibility="visible">

                <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCS
                    android:id="@+id/tvDiscountCodeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:includeFontPadding="false"
                    android:text="@string/TXT_DISCOUNT_CODE_LABEL"
                    android:textColor="@color/discount_code_label_text_color"
                    android:textSize="18sp"
                    android:visibility="@{discountViewState.getDiscountCodeLabelVisibility() ? View.VISIBLE : View.GONE}"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewDemiCS
                    android:id="@+id/tvDiscountCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@{discountViewState.component2()}"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:visibility="@{discountViewState.getDiscountCodeLabelVisibility() ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvDiscountCodeLabel" />

                <ImageView
                    android:id="@+id/imageCopyButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="20dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_copy"
                    android:visibility="@{discountViewState.getDiscountCodeLabelVisibility() ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCS
                    android:id="@+id/tvGetDiscountCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/TXT_GET_DISCOUNT_CODE_LABEL"
                    android:textColor="@color/discount_code_active_text_color"
                    android:textSize="18sp"
                    android:visibility="@{discountViewState.getDiscountLabelVisibility() ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCS
                    android:id="@+id/tvNoDiscountCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/TXT_NO_DISCOUNT_CODE_LABEL"
                    android:textColor="@color/discount_code_label_text_color"
                    android:textSize="18sp"
                    android:visibility="@{discountViewState.getNoDiscountLeftLabelVisibility() ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>


</layout>


