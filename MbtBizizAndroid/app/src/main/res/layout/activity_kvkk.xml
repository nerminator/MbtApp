<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_background">

        <include
            android:id="@+id/toolbarHtml"
            layout="@layout/toolbar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@+id/toolbarHtml"
            app:layout_constraintBottom_toTopOf="@+id/buttonContainer" />

        <!-- BOTTOM BUTTONS -->
        <LinearLayout
            android:id="@+id/buttonContainer"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_margin="5dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- CANCEL BUTTON (LEFT) -->
            <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewDemiCS
                android:id="@+id/btnDecline"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:gravity="center"
                android:background="@color/btnDeActiveButtonBgColor"
                android:text="@string/TXT_KVKK_DECLINE"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <!-- CONFIRM BUTTON (RIGHT) -->
            <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewDemiCS
                android:id="@+id/btnConfirm"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:gravity="center"
                android:background="@color/btnActiveButtonBgColor"
                android:text="@string/TXT_KVKK_CONFIRM"
                android:textColor="@android:color/white"
                android:textSize="17sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>