                        android:text="@{vm.title}"
                        android:textSize="@dimen/page_title_text_size"
                        android:textColor="@android:color/white"
                        android:visibility="@{TextUtils.isEmpty(vm.title)?View.GONE:View.VISIBLE,default=visible}"
                        tools:text="Title" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <ImageButton
                        android:onClick="@{vm::performNotification}"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:padding="16dp"
                        android:visibility="@{vm.isVisible ? View.VISIBLE : View.GONE}"
                        android:src="@drawable/icn_info" />

                </LinearLayout>-->
            </android.support.v7.widget.Toolbar>
        </FrameLayout>
    </android.support.design.widget.AppBarLayout>
</layout>
