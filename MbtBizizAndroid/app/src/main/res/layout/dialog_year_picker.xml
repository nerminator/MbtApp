<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:minWidth="300dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#394354"
            >
            <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCS
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:gravity="center"
            android:lineSpacingExtra="0sp"
            android:text="@string/TXT_PROFILE_FLEXIBLE_WORK_YEAR"
            android:textColor="#ffffff"
            android:textSize="22sp"
                android:layout_centerHorizontal="true"/>

            <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewDemiCS
                android:id="@+id/tvOk"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:gravity="center"
                android:lineSpacingExtra="0sp"
                android:text="@android:string/ok"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="#ffffff"
                android:textSize="18sp"
                android:layout_alignParentEnd="true"
                />

        </RelativeLayout>

        <!--android:fontFamily="@font/turkcellsatura_demi"-->

        <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.ThemedNumberPicker
            android:textSize="20sp"
            android:descendantFocusability="blocksDescendants"
            android:background="@color/density_dialog_bgc"
            android:id="@+id/yearPicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="200dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvHeader"/>

    </LinearLayout>
</layout>