<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="data"
            type="com.daimler.biziz.android.network.entity.food.FoodInfo"/>

        <variable
            name="dataShuttle"
            type="com.daimler.biziz.android.network.entity.food.ShuttleInfo"/>
    </data>

    <android.support.v4.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:descendantFocusability="blocksDescendants"
        >

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:animateLayoutChanges="true"
            tools:context=".ui.foodMenu.FoodMenuFragment">

            <android.support.v7.widget.RecyclerView
                android:id="@+id/rcyclerFoodMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                app:layoutManager="android.support.v7.widget.LinearLayoutManager"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvDate"
                tools:listitem="@layout/item_food_menu" />


            <com.daimler.biziz.android.uiControls.TextViewRegularCA
                android:id="@+id/tvTitleShuttle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="30dp"
                android:paddingStart="20dp"
                android:paddingBottom="5dp"
                android:textColor="#ffffff"
                android:textSize="22sp"
                android:text="@{dataShuttle.header}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/rcyclerFoodMenu"
                tools:text="Cafeteria Service Times" />



            <android.support.v7.widget.RecyclerView
                android:id="@+id/rcyclerShuttle"
                android:nestedScrollingEnabled="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                app:layoutManager="android.support.v7.widget.LinearLayoutManager"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvTitleShuttle"
                tools:listitem="@layout/item_shuttle"
                />


        </LinearLayout>
    </android.support.v4.widget.NestedScrollView>

</layout>