<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_background"
        android:padding="14dp"
        tools:context=".ui.login.LoginFragment">

        <ImageButton
            android:id="@+id/imageView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/tvMainTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvMainTitle"
            app:srcCompat="@drawable/icn_info" />

        <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.ButtonDemiCS
            android:id="@+id/btnLogin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="19dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="19dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/button_bg_active_deactive"
            android:enabled="true"
            android:onClick="@{vm::performClick}"
            android:text="@string/TXT_LOGIN_WELCOME_BUTTON"
            android:textAllCaps="false"
            android:textColor="@drawable/button_text_color_state"
            android:textSize="17.3sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCS
            android:id="@+id/tvDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="50dp"
            android:lineSpacingExtra="7sp"
            android:text="@string/TXT_LOGIN_WELCOME_DESCRIPTION"
            android:textAlignment="viewStart"
            android:textColor="@android:color/white"
            android:textSize="17.3sp"
            app:layout_constraintBottom_toTopOf="@+id/btnLogin"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="Description" />

        <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCA
            android:id="@+id/tvMainTitle"
            android:layout_width="wrap_content"
            android:layout_height="?attr/actionBarSize"
            android:gravity="center"
            android:text="@string/TXT_MB"
            android:textColor="@android:color/white"
            android:textSize="21.3sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.daimlertruck.dtag.internal.android.mbt.test.uiControls.TextViewRegularCS
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="19dp"
            android:layout_marginBottom="40dp"
            android:text="@string/TXT_LOGIN_WELCOME_HEADER"
            android:textAlignment="textStart"
            android:textColor="@color/fiftyPercentOpacityTextColor"
            android:textSize="24sp"
            app:layout_constraintBottom_toTopOf="@+id/tvDescription"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="@string/TXT_LOGIN_WELCOME_HEADER" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <data>

        <variable
            name="vm"
            type="com.daimlertruck.dtag.internal.android.mbt.test.ui.login.VMLogin" />
    </data>
</layout>
